# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy to .env.production and update with production values
# ============================================================================

# SUPABASE - Production Project
VITE_SUPABASE_URL=https://your-prod-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_prod_publishable_key
VITE_SUPABASE_PROJECT_ID=your_prod_project_id

# OAUTH ENDPOINTS - Production
VITE_SUPABASE_OAUTH_AUTHORIZE=https://your-prod-project-id.supabase.co/auth/v1/oauth/authorize
VITE_SUPABASE_OAUTH_TOKEN=https://your-prod-project-id.supabase.co/auth/v1/oauth/token
VITE_SUPABASE_OAUTH_JWKS=https://your-prod-project-id.supabase.co/auth/v1/.well-known/jwks.json
VITE_SUPABASE_OAUTH_OIDC_DISCOVERY=https://your-prod-project-id.supabase.co/auth/v1/.well-known/openid-configuration

# API - Production
VITE_API_URL=https://your-prod-project-id.supabase.co/functions/v1

# OAUTH PROVIDERS - Production
VITE_GOOGLE_OAUTH_ENABLED=true
VITE_GITHUB_OAUTH_ENABLED=true
VITE_MICROSOFT_OAUTH_ENABLED=true

# CALLBACK URLS - Production
VITE_DEV_CALLBACK_URL=https://yourdomain.com/auth/callback
VITE_PROD_CALLBACK_URL=https://yourdomain.com/auth/callback

# APPLICATION - Production
VITE_APP_NAME=Job Orbit
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

# FEATURES - Production
VITE_ENABLE_CHROME_EXTENSION=true
VITE_ENABLE_REAL_TIME_SYNC=true
VITE_ENABLE_OFFLINE_MODE=true

# MONITORING - Production
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/projectid
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
