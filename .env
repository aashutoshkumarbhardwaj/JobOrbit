# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Supabase Project URL
VITE_SUPABASE_URL=https://dsbkjkwefszqqzukgdtk.supabase.co

# Supabase Publishable Key (Safe to expose in frontend)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_KbTCR-8BEKmM3AZYDGauhg_A3i41bVt

# Supabase Project ID (extracted from URL)
VITE_SUPABASE_PROJECT_ID=dsbkjkwefszqqzukgdtk

# ============================================================================
# SUPABASE OAUTH CONFIGURATION
# ============================================================================


VITE_SUPABASE_OAUTH_AUTHORIZE=https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/oauth/authorize


VITE_SUPABASE_OAUTH_TOKEN=https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/oauth/token


VITE_SUPABASE_OAUTH_JWKS=https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/.well-known/jwks.json


VITE_SUPABASE_OAUTH_OIDC_DISCOVERY=https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/.well-known/openid-configuration


VITE_API_URL=https://dsbkjkwefszqqzukgdtk.supabase.co/functions/v1

# Optional: Custom Backend API (if using external backend)
# VITE_CUSTOM_API_URL=http://localhost:3000/api/v1

# ============================================================================
# EXTENSION TOKEN SECURITY
# ============================================================================

# Secret key for signing Extension Session Tokens (1 hour validity)
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters long for HS256
# IMPORTANT: Keep this secret, never commit to public repos
VITE_EXTENSION_TOKEN_SECRET=your-super-secret-extension-token-key-min-32-chars-12345678

# Also add to Supabase Edge Functions environment:
# In Supabase Dashboard → Edge Functions → Settings → Environment Variables
# Add: EXTENSION_TOKEN_SECRET=same-value-as-above

# ============================================================================
# OAUTH PROVIDERS (Configure in Supabase Dashboard)
# ============================================================================

# GOOGLE OAUTH
# 1. Go to Google Cloud Console (https://console.cloud.google.com)
# 2. Create OAuth 2.0 credentials (Web Application)
# 3. Add redirect URI: https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/callback
# 4. Copy Client ID and Client Secret to Supabase Dashboard
# 5. In Supabase: Authentication → Providers → Google

VITE_GOOGLE_OAUTH_ENABLED=true
# VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# GITHUB OAUTH
# 1. Go to GitHub Settings → Developer settings → OAuth Apps
# 2. Create New OAuth App
# 3. Set Authorization callback URL: https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/callback
# 4. Copy Client ID and Client Secret to Supabase Dashboard
# 5. In Supabase: Authentication → Providers → GitHub

VITE_GITHUB_OAUTH_ENABLED=true
# VITE_GITHUB_CLIENT_ID=your_github_client_id

# MICROSOFT OAUTH (Optional)
# 1. Go to Azure Portal (https://portal.azure.com)
# 2. Register an application
# 3. Add redirect URI: https://dsbkjkwefszqqzukgdtk.supabase.co/auth/v1/callback
# 4. Copy Application (client) ID and Client Secret to Supabase Dashboard
# 5. In Supabase: Authentication → Providers → Azure

VITE_MICROSOFT_OAUTH_ENABLED=false
# VITE_MICROSOFT_CLIENT_ID=your_azure_client_id

# ============================================================================
# REDIRECT URLS FOR OAUTH CALLBACKS
# ============================================================================

# Development Environment
VITE_DEV_CALLBACK_URL=http://localhost:5173/auth/callback

# Production Environment
VITE_PROD_CALLBACK_URL=https://yourdomain.com/auth/callback

# Chrome Extension (if using popup-based auth)
VITE_EXTENSION_CALLBACK_URL=chrome://extension-id/popup.html

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# App Name
VITE_APP_NAME=Job Orbit

# App Version
VITE_APP_VERSION=1.0.0

# Environment
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_CHROME_EXTENSION=true
VITE_ENABLE_REAL_TIME_SYNC=true
VITE_ENABLE_OFFLINE_MODE=true

# ============================================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================================

# Sentry Error Tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/projectid

# Google Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# NOTES
# ============================================================================
# - Never commit sensitive data to version control
# - Use .env.local for local development
# - Use .env.production for production secrets
# - Keep VITE_SUPABASE_PUBLISHABLE_KEY safe but it's meant to be exposed
# - Never expose service role keys in frontend code
# ============================================================================

