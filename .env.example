# ============================================================================
# ENVIRONMENT VARIABLES - EXAMPLE FILE
# Copy this to .env and fill in your values
# ============================================================================

# SUPABASE CONFIGURATION
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# OAUTH ENDPOINTS (Auto-configured by Supabase)
VITE_SUPABASE_OAUTH_AUTHORIZE=https://your-project-id.supabase.co/auth/v1/oauth/authorize
VITE_SUPABASE_OAUTH_TOKEN=https://your-project-id.supabase.co/auth/v1/oauth/token
VITE_SUPABASE_OAUTH_JWKS=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json
VITE_SUPABASE_OAUTH_OIDC_DISCOVERY=https://your-project-id.supabase.co/auth/v1/.well-known/openid-configuration

# API CONFIGURATION
VITE_API_URL=https://your-project-id.supabase.co/functions/v1

# OAUTH PROVIDERS
VITE_GOOGLE_OAUTH_ENABLED=true
VITE_GITHUB_OAUTH_ENABLED=true
VITE_MICROSOFT_OAUTH_ENABLED=false

# CALLBACK URLS
VITE_DEV_CALLBACK_URL=http://localhost:5173/auth/callback
VITE_PROD_CALLBACK_URL=https://yourdomain.com/auth/callback

# APPLICATION
VITE_APP_NAME=Job Orbit
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# FEATURES
VITE_ENABLE_CHROME_EXTENSION=true
VITE_ENABLE_REAL_TIME_SYNC=true
VITE_ENABLE_OFFLINE_MODE=true
